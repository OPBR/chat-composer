{
  "name": "@chat-composer/core",
  "version": "1.0.1",
  "description": "Framework-agnostic rich-text input for AI chat — @mentions, attachments, code detection, structured JSON output",
  "keywords": [
    "ai",
    "chat",
    "input",
    "composer",
    "mention",
    "attachment",
    "code-block",
    "contenteditable",
    "structured-data",
    "rich-text"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
