{
  "name": "@chat-composer/vue",
  "version": "1.0.1",
  "description": "Vue 3 composable and components for chat-composer — useComposer, ComposerInput, MentionDropdown, AttachmentList",
  "keywords": [
    "ai",
    "chat",
    "vue",
    "vue3",
    "composer",
    "mention",
    "attachment",
    "input",
    "contenteditable",
    "rich-text"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@chat-composer/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "@tsdown/css": "^0.22.3",
    "eslint-plugin-vue": "^10.9.2",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "unplugin-vue": "^7.2.0",
    "vue": "^3.5.0",
    "vue-tsc": "^3.3.0"
  }
}
